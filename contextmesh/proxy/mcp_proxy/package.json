{
  "name": "@contextmesh/mcp-proxy",
  "version": "0.1.0",
  "description": "MCP proxy server for ContextMesh compression",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test:e2e": "node test_proxy.mjs",
    "test:e2e:multi": "node test_proxy_multi.mjs",
    "test:e2e:http": "node test_proxy_http.mjs"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.10",
    "@modelcontextprotocol/sdk": "^1.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
