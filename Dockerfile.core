FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml README.md config.yaml ./
COPY contextmesh/ contextmesh/
COPY grpc_server.py .

RUN pip install --no-cache-dir -e ".[embeddings]"

EXPOSE 50051

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD python -c "from contextmesh.grpc.client import CompressionClient; \
         c = CompressionClient(); exit(0 if c.health_check() else 1)"

CMD ["python", "grpc_server.py", "--port", "50051"]
